{{- $paths := slice -}}
{{- range .Site.Sections -}}
  {{- if and (ne .Type "sitemap") -}}
    {{- $paths = $paths | append .Params.url -}}
    {{- range $index, $page := (where .Site.Pages "Section" .Type) -}}
      {{- if lt $index 10 -}}
        {{- with $page.Params.url -}}
          {{- $paths = $paths | append . -}}
        {{- end -}}
      {{- end -}}
    {{- end -}}
  {{- end -}}
{{- end -}}

{{- $paths | uniq | jsonify -}}

